# Credenciais públicas do Supabase (Dashboard → Project Settings → API).
# Copie este arquivo para `.env` e preencha com os valores do SEU projeto.
#
# ATENÇÃO: a anon key é pública por natureza (vai para o navegador). A segurança
# vem das políticas de RLS + da Edge Function protegida por senha — NÃO coloque
# aqui a service_role key.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui
